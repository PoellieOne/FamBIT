---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getHomeContent, getSiteContent } from "../lib/content";
import { getLocaleFromPath, localizedPath } from "../lib/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const home = getHomeContent(locale);
const site = getSiteContent(locale);
---

<BaseLayout
  title={`FamBIT | ${home.hero.title}`}
  lang={locale}
  homeHero={true}
  heroTitle={home.hero.title}
  heroSubhead={home.hero.subhead}
  heroImage="/images/home-main-banner.jpg"
  heroImageAlt="Community members standing together outdoors"
  heroPrimaryHref={localizedPath(locale, home.cta.href)}
  heroPrimaryLabel={home.cta.label}
  heroSecondaryHref={localizedPath(locale, "/community")}
  heroSecondaryLabel="Community culture"
>

  <section class="c-home-panel">
    {home.narrative.paragraphs.map((paragraph) => (
      <p class="m-0 mt-4 text-base text-slate-800 first:mt-0">{paragraph}</p>
    ))}
  </section>

  <section class="c-home-strip">
    <h2 class="m-0 text-2xl font-bold text-slate-950">Mission rhythm</h2>
    <p class="m-0 mt-3 text-base text-slate-800">The core routine below translates values into everyday behavior.</p>
    <h3 class="m-0 mt-5 text-lg font-semibold text-slate-950">{home.whatThisMeans.title}</h3>
    <ul class="mb-0 mt-3 list-disc space-y-3 pl-5 text-base text-slate-800">
      {home.whatThisMeans.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="c-home-panel">
    <h2 class="m-0 text-2xl font-bold text-slate-950">Trust and safety emphasis</h2>
    <p class="m-0 mt-3 text-base text-slate-800">The next step in this flow is practical safety guidance.</p>
    <p class="m-0 mt-4">
      <a class="font-semibold text-[var(--accent-strong)]" href={localizedPath(locale, home.cta.href)}>
        {home.cta.label}
      </a>
    </p>
    <p class="m-0 mt-4 text-sm font-medium text-slate-900">{home.trust.microcopy}</p>
  </section>

  <section class="c-home-panel">
    <h2 class="m-0 text-2xl font-bold text-slate-950">{site.legal.whatWeAre.title}</h2>
    <p class="m-0 mt-3 text-base text-slate-800">{site.legal.whatWeAre.intro}</p>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      {site.legal.whatWeAre.items.map((item) => <p class="story-card m-0 text-base text-slate-800">{item}</p>)}
    </div>
    <h3 class="m-0 mt-6 text-lg font-bold text-slate-950">{site.legal.whatWeAreNot.title}</h3>
    <p class="m-0 mt-3 text-base text-slate-800">{site.legal.whatWeAreNot.intro}</p>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      {site.legal.whatWeAreNot.items.map((item) => <p class="story-card m-0 text-base text-slate-800">{item}</p>)}
    </div>
    <p class="m-0 mt-6 text-base text-slate-800">{site.legal.disclaimersIntro}</p>
    <ul class="c-chip-list">
      {site.legal.disclaimers.map((item) => <li class="c-chip">{item}</li>)}
    </ul>
  </section>
</BaseLayout>
