---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getHomeContent, getSiteContent } from "../lib/content";
import { getLocaleFromPath, localizedPath } from "../lib/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const home = getHomeContent(locale);
const site = getSiteContent(locale);
---

<BaseLayout title={`FamBIT | ${home.hero.title}`} lang={locale}>
  <section class="hero-banner atmo-panel min-h-[20rem]">
    <img
      src="/images/home-main-banner.jpg"
      alt="Community members standing together outdoors"
      class="h-[20rem] w-full object-cover md:h-[28rem]"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-banner-content text-white">
      <h1 class="m-0 text-3xl font-extrabold leading-tight tracking-tight md:text-5xl">{home.hero.title}</h1>
      <p class="mb-0 mt-4 max-w-[35rem] text-base text-slate-100 md:text-lg">{home.hero.subhead}</p>
    </div>
  </section>

  <section class="atmo-panel p-6">
    {home.narrative.paragraphs.map((paragraph) => (
      <p class="mt-0 text-base text-slate-800 last:mb-0">{paragraph}</p>
    ))}
  </section>

  <section class="soft-strip p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">Mission rhythm</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">The core routine below translates values into everyday behavior.</p>
    <h3 class="mb-0 mt-4 text-lg font-semibold text-slate-950">{home.whatThisMeans.title}</h3>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {home.whatThisMeans.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="atmo-panel p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">Trust and safety emphasis</h2>
    <p class="mt-0 text-base text-slate-800">The next step in this flow is practical safety guidance.</p>
    <p class="mb-0 mt-3">
      <a class="font-semibold text-[var(--accent-strong)]" href={localizedPath(locale, home.cta.href)}>
        {home.cta.label}
      </a>
    </p>
    <p class="mb-0 mt-3 text-sm font-medium text-slate-900">{home.trust.microcopy}</p>
  </section>

  <section class="atmo-panel p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{site.legal.whatWeAre.title}</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">{site.legal.whatWeAre.intro}</p>
    <div class="mt-3 grid gap-3 md:grid-cols-3">
      {site.legal.whatWeAre.items.map((item) => <p class="story-card m-0 text-base text-slate-800">{item}</p>)}
    </div>
    <h3 class="mb-0 mt-4 text-lg font-bold text-slate-950">{site.legal.whatWeAreNot.title}</h3>
    <p class="mb-0 mt-3 text-base text-slate-800">{site.legal.whatWeAreNot.intro}</p>
    <div class="mt-3 grid gap-3 md:grid-cols-3">
      {site.legal.whatWeAreNot.items.map((item) => <p class="story-card m-0 text-base text-slate-800">{item}</p>)}
    </div>
    <p class="mb-0 mt-4 text-base text-slate-800">{site.legal.disclaimersIntro}</p>
    <div class="mt-3 flex flex-wrap gap-2 text-sm text-slate-700">
      {site.legal.disclaimers.map((item) => <span class="rounded-full border border-slate-300 bg-white px-3 py-1">{item}</span>)}
    </div>
  </section>
</BaseLayout>
