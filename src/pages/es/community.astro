---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCommunityContent } from "../../lib/content";
import { getLocaleFromPath } from "../../lib/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const community = getCommunityContent(locale);
---

<BaseLayout title={`FamBIT | ${community.hero.title}`} lang={locale}>
  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h1 class="m-0 text-2xl font-extrabold tracking-tight text-slate-950">{community.hero.title}</h1>
    <p class="mb-0 mt-3 text-base text-slate-800">{community.hero.intro}</p>
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{community.culture.title}</h2>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {community.culture.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{community.contribute.title}</h2>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {community.contribute.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{community.boundaries.title}</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">{community.boundaries.body}</p>
  </section>
</BaseLayout>
