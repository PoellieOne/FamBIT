---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VerifiedLinks from "../../components/VerifiedLinks.astro";
import { getSafetyContent, getSiteContent } from "../../lib/content";
import { getLocaleFromPath } from "../../lib/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const safety = getSafetyContent(locale);
const site = getSiteContent(locale);
---

<BaseLayout title={`FamBIT | ${safety.hero.title}`} lang={locale} includeGlobalTrustPanels={false}>
  <section class="rounded-lg border-2 border-slate-400 bg-white p-6">
    <h1 class="m-0 text-2xl font-extrabold tracking-tight text-slate-950">{safety.hero.title}</h1>
    <p class="mb-0 mt-3 text-base text-slate-800">{safety.hero.intro}</p>
  </section>

  <VerifiedLinks
    title={site.verifiedLinks.title}
    xLabel={site.verifiedLinks.xLabel}
    telegramLabel={site.verifiedLinks.telegramLabel}
    pumpfunLabel={site.verifiedLinks.pumpfunLabel}
  />

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{safety.checks.title}</h2>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {safety.checks.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{safety.reminder.title}</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">{safety.reminder.body}</p>
  </section>
</BaseLayout>
