---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VerifiedLinks from "../../components/VerifiedLinks.astro";
import { getSafetyContent, getSiteContent } from "../../lib/content";
import { getLocaleFromPath, localizedPath } from "../../lib/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const safety = getSafetyContent(locale);
const site = getSiteContent(locale);
---

<BaseLayout
  title={`FamBIT | ${safety.hero.title}`}
  lang={locale}
  includeGlobalTrustPanels={false}
  heroTitle={safety.hero.title}
  heroSubhead={safety.hero.subhead}
  heroPrimaryHref={localizedPath(locale, safety.cta.href)}
  heroPrimaryLabel={safety.cta.label}
  heroSecondaryHref={localizedPath(locale, "/community")}
  heroSecondaryLabel="Siguiente comunidad"
>

  <section class="atmo-panel p-6">
    {safety.narrative.paragraphs.map((paragraph) => (
      <p class="mt-0 text-base text-slate-800 last:mb-0">{paragraph}</p>
    ))}
  </section>

  <VerifiedLinks
    title={site.verifiedLinks.title}
    xLabel={site.verifiedLinks.xLabel}
    telegramLabel={site.verifiedLinks.telegramLabel}
    pumpfunLabel={site.verifiedLinks.pumpfunLabel}
  />

  <section class="soft-strip p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{safety.whatThisMeans.title}</h2>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {safety.whatThisMeans.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="atmo-panel p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{safety.verification.title}</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">{safety.verification.intro}</p>
    <p class="mb-0 mt-3 text-base text-slate-800">{safety.verification.instruction}</p>
  </section>

  <section class="atmo-panel p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{safety.adminRules.title}</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">{safety.adminRules.intro}</p>
    <div class="mt-3 grid gap-3 md:grid-cols-3">
      {safety.adminRules.items.map((item) => <p class="story-card m-0 text-base text-slate-800">{item}</p>)}
    </div>
  </section>

  <section class="atmo-panel p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{safety.reporting.title}</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">{safety.reporting.intro}</p>
    <ol class="mb-0 mt-3 list-decimal space-y-2 pl-5 text-base text-slate-800">
      {safety.reporting.steps.map((item) => <li>{item}</li>)}
    </ol>
    <p class="mb-0 mt-4">
      <a class="font-semibold text-[var(--accent-strong)]" href={localizedPath(locale, safety.cta.href)}>{safety.cta.label}</a>
    </p>
    <p class="mb-0 mt-3 text-sm font-medium text-slate-900">{safety.trust.microcopy}</p>
  </section>
</BaseLayout>
