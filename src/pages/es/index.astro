---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getHomeContent, getSiteContent } from "../../lib/content";
import { getLocaleFromPath, localizedPath } from "../../lib/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const home = getHomeContent(locale);
const site = getSiteContent(locale);
---

<BaseLayout title={`FamBIT | ${home.hero.title}`} lang={locale}>
  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h1 class="m-0 text-2xl font-extrabold tracking-tight text-slate-950">{home.hero.title}</h1>
    <p class="mb-0 mt-3 text-base text-slate-800">{home.hero.subhead}</p>
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    {home.narrative.paragraphs.map((paragraph) => (
      <p class="mt-0 text-base text-slate-800 last:mb-0">{paragraph}</p>
    ))}
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{home.whatThisMeans.title}</h2>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {home.whatThisMeans.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <p class="mb-0 mt-3">
      <a class="font-semibold text-[var(--accent-strong)]" href={localizedPath(locale, home.cta.href)}>
        {home.cta.label}
      </a>
    </p>
    <p class="mb-0 mt-3 text-sm font-medium text-slate-900">{home.trust.microcopy}</p>
  </section>

  <section class="rounded-lg border border-slate-300 bg-white/90 p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{site.legal.whatWeAre.title}</h2>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {site.legal.whatWeAre.items.map((item) => <li>{item}</li>)}
    </ul>
    <h3 class="mb-0 mt-4 text-lg font-bold text-slate-950">{site.legal.whatWeAreNot.title}</h3>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {site.legal.whatWeAreNot.items.map((item) => <li>{item}</li>)}
    </ul>
    <ul class="mb-0 mt-4 list-disc pl-5 text-sm text-slate-700">
      {site.legal.disclaimers.map((item) => <li>{item}</li>)}
    </ul>
  </section>
</BaseLayout>
