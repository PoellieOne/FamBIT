---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocaleFromPath, localizedPath } from "../lib/i18n";
import { getRoadmapContent } from "../lib/content";

const locale = getLocaleFromPath(Astro.url.pathname);
const roadmap = getRoadmapContent(locale);
---

<BaseLayout
  title={`FamBIT | ${roadmap.hero.title}`}
  lang={locale}
  heroTitle={roadmap.hero.title}
  heroSubhead={roadmap.hero.subhead}
  heroImage="/images/roadmap-community-sunset.jpg"
  heroImageAlt="Community group facing a shared horizon at sunset"
  heroPrimaryHref={localizedPath(locale, roadmap.cta.href)}
  heroPrimaryLabel={roadmap.cta.label}
  heroSecondaryHref={localizedPath(locale, "/community")}
  heroSecondaryLabel="Community context"
>

  <section class="atmo-panel p-6">
    {roadmap.narrative.paragraphs.map((paragraph) => (
      <p class="mt-0 text-base text-slate-800 last:mb-0">{paragraph}</p>
    ))}
  </section>

  <section class="soft-strip p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{roadmap.whatThisMeans.title}</h2>
    <ul class="mb-0 mt-3 list-disc space-y-2 pl-5 text-base text-slate-800">
      {roadmap.whatThisMeans.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="atmo-panel p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">Shared horizon</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">
      Roadmap progress is meaningful when people can see it together in public, not through speculation.
    </p>
    <figure class="story-media mt-4 m-0">
      <img src="/images/roadmap-community-sunset.jpg" alt="A group gathered at sunset symbolizing shared long term direction" loading="lazy" />
      <figcaption class="story-media-body text-sm text-slate-700">
        Visibility and consistency build trust across every phase.
      </figcaption>
    </figure>
  </section>

  <section class="atmo-panel p-6">
    <h2 class="m-0 text-xl font-bold text-slate-950">{roadmap.phasesTitle}</h2>
    <p class="mb-0 mt-3 text-base text-slate-800">
      Each phase keeps one clear focus so progress stays visible and realistic.
    </p>
    <div class="mt-4 space-y-4 border-l-2 border-slate-200 pl-4">
      {roadmap.phases.map((phase) => (
        <article class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
          <h3 class="m-0 text-lg font-bold text-slate-950">{phase.name}</h3>
          <p class="mb-0 mt-2 text-sm font-semibold uppercase tracking-wide text-slate-700">{phase.window}</p>
          <p class="mb-0 mt-2 text-base text-slate-800">{phase.summary}</p>
          <ul class="mb-0 mt-2 list-disc space-y-1 pl-5 text-base text-slate-800">
            {phase.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="atmo-panel p-6">
    <p class="mb-0 mt-3">
      <a class="font-semibold text-[var(--accent-strong)]" href={localizedPath(locale, roadmap.cta.href)}>{roadmap.cta.label}</a>
    </p>
    <p class="mb-0 mt-3 text-sm font-medium text-slate-900">{roadmap.trust.microcopy}</p>
  </section>
</BaseLayout>
