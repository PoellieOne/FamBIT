---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import VerifiedLinks from "../components/VerifiedLinks.astro";
import SafetyNotice from "../components/SafetyNotice.astro";
import { getSiteContent } from "../lib/content";
import { getLocaleFromPath, getPathWithoutLocale, type Locale } from "../lib/i18n";
import "../styles/global.css";

interface Props {
  title?: string;
  lang?: Locale;
  includeGlobalTrustPanels?: boolean;
  homeHero?: boolean;
  heroTitle: string;
  heroSubhead: string;
  heroImage?: string;
  heroImageAlt?: string;
  heroPrimaryHref: string;
  heroPrimaryLabel: string;
  heroSecondaryHref: string;
  heroSecondaryLabel: string;
}

const pathLocale = getLocaleFromPath(Astro.url.pathname);
const { lang = pathLocale, includeGlobalTrustPanels = true, homeHero = false } = Astro.props;
const site = getSiteContent(lang);
const pageTitle = Astro.props.title || site.meta.defaultTitle;
const basePath = getPathWithoutLocale(Astro.url.pathname);
const {
  heroTitle,
  heroSubhead,
  heroImage,
  heroImageAlt,
  heroPrimaryHref,
  heroPrimaryLabel,
  heroSecondaryHref,
  heroSecondaryLabel
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={site.meta.description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class:list={["shell", homeHero && "c-home-shell"]}>
      <a href="#main" class="sr-only focus:not-sr-only">{site.a11y.skipToMain}</a>
      {
        homeHero && (
          <Header
            lang={lang}
            currentPath={basePath}
            floatingViewport={true}
            brand={site.header.brand}
            languageLabel={site.header.languageLabel}
            nav={site.header.nav}
            language={site.language}
          />
        )
      }
      <section
        id={homeHero ? "HOME-HERO" : undefined}
        class:list={[
          "hero-system",
          "relative",
          "overflow-hidden",
          homeHero ? "rounded-none" : "rounded-[1.25rem]",
          "border",
          "border-slate-300",
          "bg-slate-900",
          homeHero && "c-home-hero c-home-bleed c-home-hero-stage"
        ]}
      >
        {
          heroImage ? (
            <img
              src={heroImage}
              alt={heroImageAlt || heroTitle}
                class:list={["w-full", "object-cover", homeHero ? "h-[100svh] min-h-[100vh]" : "h-[28rem] md:h-[34rem]"]}
                loading="eager"
                fetchpriority="high"
              />
          ) : (
            <div class="h-[26rem] bg-[radial-gradient(circle_at_20%_20%,rgba(111,61,244,0.28),transparent_42%),radial-gradient(circle_at_78%_0%,rgba(102,194,165,0.24),transparent_40%),linear-gradient(180deg,#1f2937,#111827)]"></div>
          )
        }
         <div class:list={["absolute", "inset-0", homeHero ? "c-home-hero-mask" : "bg-gradient-to-b from-slate-900/25 via-slate-900/45 to-slate-900/82"]}></div>
         <div class:list={["absolute", "inset-0", homeHero ? "c-home-hero-inner" : "p-4 md:p-8"]}>
           {
             !homeHero && (
               <Header
                 lang={lang}
                 currentPath={basePath}
                 brand={site.header.brand}
                 languageLabel={site.header.languageLabel}
                 nav={site.header.nav}
                 language={site.language}
               />
             )
           }
          <div class:list={["max-w-3xl", homeHero ? "mt-20 md:mt-28" : "mt-8 md:mt-14"]}>
            <p id="H-02a" data-stam-block="H-02a" class:list={["m-0", "font-semibold", "uppercase", "text-slate-200", homeHero ? "text-[0.72rem] tracking-[0.2em]" : "text-sm tracking-[0.16em]"]}>Safety-first community</p>
            <h1 id="H-02b" data-stam-block="H-02b" class:list={["mt-2", "font-extrabold", "leading-tight", "tracking-tight", "text-white", homeHero ? "text-4xl md:text-6xl" : "text-3xl md:text-5xl"]}>{heroTitle}</h1>
            <p id="H-02c" data-stam-block="H-02c" class:list={["mb-0", "max-w-2xl", "text-slate-100", homeHero ? "mt-5 text-base leading-7 md:text-xl" : "mt-4 text-base md:text-lg"]}>{heroSubhead}</p>
            <div id="H-02d" data-stam-block="H-02d" class:list={["flex", "flex-wrap", homeHero ? "mt-8 gap-4" : "mt-6 gap-3"]}>
              <a href={heroPrimaryHref} class="rounded-full bg-white px-5 py-2.5 text-sm font-bold text-slate-900">{heroPrimaryLabel}</a>
              <a href={heroSecondaryHref} class="rounded-full border border-white/35 px-5 py-2.5 text-sm font-bold text-white">
                {heroSecondaryLabel}
              </a>
            </div>
            {homeHero && <p id="H-02e" data-stam-block="H-02e" class="mb-0 mt-6 text-sm font-medium text-slate-100/90">Verify first, then participate through official channels only.</p>}
          </div>
        </div>
      </section>
      <main id="main" class:list={[homeHero ? "c-home-main" : "mt-6 space-y-4"]} tabindex="-1">
        <slot />
        {
          includeGlobalTrustPanels && (
            <>
              <div data-stam-block="H-05a">
                <VerifiedLinks
                  title={site.verifiedLinks.title}
                  xLabel={site.verifiedLinks.xLabel}
                  telegramLabel={site.verifiedLinks.telegramLabel}
                  pumpfunLabel={site.verifiedLinks.pumpfunLabel}
                />
              </div>
              <div data-stam-block="H-05b">
                <SafetyNotice title={site.safetyNotice.title} body={site.safetyNotice.body} />
              </div>
            </>
          )
        }
      </main>
      <div class="mt-6" data-stam-block="H-06a">
        <Footer
          darkBleed={homeHero}
          tagline={site.footer.tagline}
          reminder={site.footer.reminder}
          disclaimer={site.footer.disclaimer}
          aboutLabel={site.footer.labels.about}
          safetyLabel={site.footer.labels.safety}
          linksTitle={site.verifiedLinks.title}
          xLabel={site.verifiedLinks.xLabel}
          telegramLabel={site.verifiedLinks.telegramLabel}
          pumpfunLabel={site.verifiedLinks.pumpfunLabel}
        />
      </div>
    </div>
  </body>
</html>
