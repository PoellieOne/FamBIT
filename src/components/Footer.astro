---
import { OFFICIAL_LINKS } from "../lib/i18n";

interface Props {
  tagline: string;
  reminder: string;
  disclaimer: string;
  aboutLabel: string;
  safetyLabel: string;
  linksTitle: string;
  xLabel: string;
  telegramLabel: string;
  pumpfunLabel: string;
}

const { tagline, reminder, disclaimer, aboutLabel, safetyLabel, linksTitle, xLabel, telegramLabel, pumpfunLabel } = Astro.props;
---

<footer class="c-footer">
  <div class="c-footer-grid">
    <section>
      <h2 class="c-footer-title">{aboutLabel}</h2>
      <p class="c-footer-copy">{tagline}</p>
    </section>
    <section>
      <h2 class="c-footer-title">{safetyLabel}</h2>
      <p class="c-footer-emphasis">{reminder}</p>
      <p class="c-footer-emphasis">{disclaimer}</p>
    </section>
    <section aria-label={linksTitle}>
      <h2 class="c-footer-title">{linksTitle}</h2>
      <ul class="c-footer-list">
        <li><a class="c-footer-link" href={OFFICIAL_LINKS.x}>{xLabel}</a></li>
        <li><a class="c-footer-link" href={OFFICIAL_LINKS.telegram}>{telegramLabel}</a></li>
        <li><a class="c-footer-link" href={OFFICIAL_LINKS.pumpfun}>{pumpfunLabel}</a></li>
      </ul>
    </section>
  </div>
</footer>
