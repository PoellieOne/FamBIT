---
import { localizedPath, type Locale } from "../lib/i18n";

interface Props {
  active: Locale;
  basePath: string;
  label: string;
  language: {
    en: string;
    es: string;
  };
}

const { active, basePath, label, language } = Astro.props;
const activeLabel = active === "en" ? language.en : language.es;
---

<details class="c-lang-menu" role="group" aria-label={label}>
  <summary class="c-lang-summary">{activeLabel}</summary>
  <ul class="c-lang-list">
    <li>
      <a
        href={localizedPath("en", basePath)}
        hreflang="en"
        aria-current={active === "en" ? "page" : undefined}
        class="c-lang-link"
      >
        {language.en}
      </a>
    </li>
    <li>
      <a
        href={localizedPath("es", basePath)}
        hreflang="es"
        aria-current={active === "es" ? "page" : undefined}
        class="c-lang-link"
      >
        {language.es}
      </a>
    </li>
  </ul>
</details>
