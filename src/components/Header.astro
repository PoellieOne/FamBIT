---
import LanguageToggle from "./LanguageToggle.astro";
import { localizedPath } from "../lib/i18n";

interface Props {
  lang: "en" | "es";
  currentPath: string;
  floatingViewport?: boolean;
  brand: string;
  languageLabel: string;
  nav: {
    community: string;
    roadmap: string;
    safety: string;
    about: string;
  };
  language: {
    en: string;
    es: string;
  };
}

const { lang, currentPath, floatingViewport = false, brand, languageLabel, nav, language } = Astro.props;
const navItems = [
  { href: localizedPath(lang, "/community"), label: nav.community, key: "/community" },
  { href: localizedPath(lang, "/roadmap"), label: nav.roadmap, key: "/roadmap" },
  { href: localizedPath(lang, "/safety"), label: nav.safety, key: "/safety" },
  { href: localizedPath(lang, "/about"), label: nav.about, key: "/about" }
];
---

<header
  class:list={["c-header", "c-nav-sticky", "c-nav-floating", "c-nav-glass", floatingViewport && "c-home-nav-fixed"]}
  data-stam-block="N-01"
>
  <div class="c-header-row">
    <a href={lang === "es" ? "/es" : "/"} class="c-brand">{brand}</a>
    <nav aria-label="Primary" class="c-primary-nav" data-stam-block="N-02">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={currentPath === item.key ? "page" : undefined}
            class="c-nav-link"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div data-stam-block="N-03">
      <LanguageToggle active={lang} basePath={currentPath} label={languageLabel} language={language} />
    </div>
  </div>
</header>
