---
import LanguageToggle from "./LanguageToggle.astro";
import { localizedPath } from "../lib/i18n";

interface Props {
  lang: "en" | "es";
  currentPath: string;
  brand: string;
  languageLabel: string;
  nav: {
    home: string;
    safety: string;
    community: string;
    roadmap: string;
  };
  primaryAction: string;
  language: {
    en: string;
    es: string;
  };
}

const { lang, currentPath, brand, languageLabel, nav, primaryAction, language } = Astro.props;
const navItems = [
  { href: localizedPath(lang, "/"), label: nav.home, key: "/" },
  { href: localizedPath(lang, "/safety"), label: nav.safety, key: "/safety" },
  { href: localizedPath(lang, "/community"), label: nav.community, key: "/community" },
  { href: localizedPath(lang, "/roadmap"), label: nav.roadmap, key: "/roadmap" }
];
---

<header class="rounded-xl border border-white/30 bg-slate-950/45 p-4 text-white backdrop-blur md:p-5">
  <div class="flex flex-wrap items-center gap-3">
    <a href={lang === "es" ? "/es" : "/"} class="mr-2 text-xl font-extrabold tracking-tight">{brand}</a>
    <nav aria-label="Primary" class="flex flex-wrap gap-2 text-sm">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={currentPath === item.key ? "page" : undefined}
            class="rounded-full border border-white/20 px-3 py-1.5 font-semibold text-white/90 transition hover:bg-white/10"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a href={localizedPath(lang, "/safety")} class="ml-auto rounded-full bg-white px-4 py-2 text-sm font-bold text-slate-900">
      {primaryAction}
    </a>
    <LanguageToggle active={lang} basePath={currentPath} label={languageLabel} language={language} />
  </div>
</header>
