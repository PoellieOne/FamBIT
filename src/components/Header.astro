---
import LanguageToggle from "./LanguageToggle.astro";

interface Props {
  lang: "en" | "es";
  basePath: string;
  brand: string;
  languageLabel: string;
  language: {
    en: string;
    es: string;
  };
}

const { lang, basePath, brand, languageLabel, language } = Astro.props;
---

<header class="rounded-lg border border-slate-300 bg-white/80 p-4 md:p-6">
  <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
    <a href={lang === "es" ? "/es" : "/"} class="text-xl font-extrabold tracking-tight text-slate-950">{brand}</a>
    <LanguageToggle active={lang} basePath={basePath} label={languageLabel} language={language} />
  </div>
</header>
