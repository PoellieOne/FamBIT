---
import { OFFICIAL_LINKS } from "../lib/i18n";

interface Props {
  title: string;
  xLabel: string;
  telegramLabel: string;
  pumpfunLabel: string;
}

const { title, xLabel, telegramLabel, pumpfunLabel } = Astro.props;
---

<aside aria-label={title} class="rounded-lg border border-slate-300 bg-white/80 p-4">
  <h2 class="m-0 text-base font-semibold text-slate-950">{title}</h2>
  <ul class="mt-3 list-disc pl-5 text-sm text-slate-800">
    <li><a class="font-medium text-[var(--accent-strong)]" href={OFFICIAL_LINKS.x}>{xLabel}</a></li>
    <li><a class="font-medium text-[var(--accent-strong)]" href={OFFICIAL_LINKS.telegram}>{telegramLabel}</a></li>
    <li>
      <a class="font-medium text-[var(--accent-strong)]" href={OFFICIAL_LINKS.pumpfun}>
        {pumpfunLabel}
      </a>
    </li>
  </ul>
</aside>
